# Database
DATABASE_URL=postgresql://routing:routing_secret@localhost:5432/routing_engine

# Redis
REDIS_URL=redis://localhost:6379

# Server
PORT=3000
LOG_LEVEL=info
NODE_ENV=development

# Public URL used by providers to POST webhook callbacks
WEBHOOK_BASE_URL=https://your-domain.com

# Security
API_KEY_HEADER=X-API-Key
MERCHANT_API_KEYS=key1,key2

# Kkiapay
KKIAPAY_PUBLIC_KEY=
KKIAPAY_PRIVATE_KEY=
KKIAPAY_SECRET_KEY=
KKIAPAY_BASE_URL=https://api.kkiapay.me
KKIAPAY_SANDBOX=false

# FedaPay
FEDAPAY_SECRET_KEY=
FEDAPAY_BASE_URL=https://api.fedapay.com/v1
FEDAPAY_SANDBOX=false

# CinetPay
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
CINETPAY_BASE_URL=https://api-checkout.cinetpay.com/v2

# FeexPay
FEEXPAY_API_KEY=
FEEXPAY_BASE_URL=https://api.feexpay.me

# PayDunya
PAYDUNYA_MASTER_KEY=
PAYDUNYA_PRIVATE_KEY=
PAYDUNYA_TOKEN=
PAYDUNYA_BASE_URL=https://app.paydunya.com/api/v1

# Routing
MAX_ATTEMPTS_PER_TRANSACTION=3
SCORING_WINDOW_HOURS=1
SCORING_MIN_SAMPLES=10
DEFAULT_CURRENCY=XOF

# Jobs
STATUS_POLL_INTERVAL_MS=5000
STATUS_POLL_MAX_ATTEMPTS=12
WEBHOOK_RETRY_ATTEMPTS=5
WEBHOOK_RETRY_BACKOFF_MS=1000
