# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/payment_engine

# Redis
REDIS_URL=redis://localhost:6379

# Webhooks
WEBHOOK_BASE_URL=https://your-domain.com

# Kkiapay
KKIAPAY_PRIVATE_KEY=your-kkiapay-private-key
KKIAPAY_PUBLIC_KEY=your-kkiapay-public-key
KKIAPAY_HMAC_KEY=your-kkiapay-hmac-key
KKIAPAY_BASE_URL=https://api.kkiapay.me
KKIAPAY_TIMEOUT_MS=30000

# Fedapay
FEDAPAY_SECRET_KEY=your-fedapay-secret-key
FEDAPAY_BASE_URL=https://api.fedapay.com

# Cinetpay
CINETPAY_API_KEY=your-cinetpay-api-key
CINETPAY_SITE_ID=your-cinetpay-site-id
CINETPAY_BASE_URL=https://api-checkout.cinetpay.com

# Feexpay
FEEXPAY_API_KEY=your-feexpay-api-key
FEEXPAY_SHOP_ID=your-feexpay-shop-id
FEEXPAY_HMAC_SECRET=your-feexpay-hmac-secret
FEEXPAY_BASE_URL=https://api.feexpay.me

# Paydunya
PAYDUNYA_MASTER_KEY=your-paydunya-master-key
PAYDUNYA_PRIVATE_KEY=your-paydunya-private-key
PAYDUNYA_BASE_URL=https://app.paydunya.com/api

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Routing
MAX_FALLBACK_ATTEMPTS=3
