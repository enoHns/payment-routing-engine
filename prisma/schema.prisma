generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TxStatus {
  INITIATED
  PROVIDER_SELECTED
  PROCESSING
  REQUIRES_REDIRECT
  SUCCESS
  FAILED
  REFUNDED
}

enum AttemptStatus {
  PENDING
  SUCCESS
  FAILED
}

model Transaction {
  id             String    @id @default(uuid())
  phone          String
  country        String
  operator       String?
  amount         Decimal   @db.Decimal(18, 2)
  currency       String    @db.Char(3)
  status         TxStatus  @default(INITIATED)
  idempotencyKey String?   @unique
  webhookUrl     String?
  checkoutUrl    String?
  settledAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  attempts       Attempt[]
  auditLogs      AuditLog[]

  @@index([phone])
  @@index([status])
  @@index([idempotencyKey])
  @@map("transactions")
}

model Attempt {
  id             String        @id @default(uuid())
  transactionId  String
  providerName   String
  status         AttemptStatus @default(PENDING)
  score          Float?    @db.DoublePrecision
  providerTxId   String?
  latencyMs      Int?
  errorCode      String?
  errorMessage   String?
  webhookPayload Json?
  resolvedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  transaction    Transaction   @relation(fields: [transactionId], references: [id])

  @@index([transactionId])
  @@index([providerTxId])
  @@map("attempts")
}

model ProviderMetric {
  id             String   @id @default(uuid())
  providerName   String
  operator       String
  country        String
  windowStart    DateTime
  successCount   Int      @default(0)
  failureCount   Int      @default(0)
  totalLatencyMs BigInt   @default(0)
  sampleCount    Int      @default(0)
  updatedAt      DateTime @updatedAt

  @@unique([providerName, operator, country, windowStart])
  @@index([providerName, operator, country])
  @@map("provider_metrics")
}

model AuditLog {
  id            String   @id @default(uuid())
  transactionId String
  event         String
  payload       Json?
  createdAt     DateTime @default(now())

  transaction   Transaction @relation(fields: [transactionId], references: [id])

  @@index([transactionId])
  @@map("audit_logs")
}
