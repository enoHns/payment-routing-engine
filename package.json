{
  "name": "payment-routing-engine",
  "version": "1.0.0",
  "description": "West Africa mobile money payment routing engine",
  "main": "dist/index.js",
  "engines": { "node": ">=16.0.0" },
  "scripts": {
    "build":        "tsc",
    "start":        "node dist/index.js",
    "dev":          "nodemon",
    "dev:once":     "ts-node -r tsconfig-paths/register src/index.ts",
    "test":         "vitest run",
    "test:coverage":"vitest run --coverage",
    "test:watch":   "vitest",
    "lint":         "tsc --noEmit",
    "db:generate":  "prisma generate",
    "db:migrate":   "prisma migrate dev",
    "db:studio":    "prisma studio"
  },
  "dependencies": {
    "@fastify/helmet":     "^10.1.1",
    "@fastify/rate-limit": "^7.6.0",
    "@prisma/client":      "^4.6.1",
    "axios":               "^1.1.3",
    "bullmq":              "^2.4.0",
    "dotenv":              "^16.0.3",
    "fastify":             "^4.9.2",
    "fastify-plugin":      "^4.4.0",
    "ioredis":             "^5.2.4",
    "pino":                "^8.7.0",
    "pino-pretty":         "^9.1.1",
    "uuid":                "^9.0.0",
    "zod":                 "^3.19.1"
  },
  "devDependencies": {
    "@types/node":           "^18.11.3",
    "@types/uuid":           "^9.0.0",
    "@vitest/coverage-c8":   "^0.25.1",
    "nodemon":               "^2.0.20",
    "prisma":                "^4.6.1",
    "ts-node":               "^10.9.1",
    "tsconfig-paths":        "^4.1.1",
    "typescript":            "^4.9.3",
    "vitest":                "^0.25.1"
  }
}
