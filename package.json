{
  "name": "payment-routing-engine",
  "version": "0.5.0",
  "description": "West Africa mobile money payment routing engine",
  "main": "dist/index.js",
  "engines": { "node": ">=12.0.0" },
  "scripts": {
    "build":        "tsc",
    "start":        "node dist/index.js",
    "dev":          "nodemon",
    "dev:once":     "ts-node -r tsconfig-paths/register src/index.ts",
    "test":         "jest --forceExit --detectOpenHandles",
    "test:coverage":"jest --forceExit --coverage",
    "test:watch":   "jest --watch",
    "lint":         "tsc --noEmit",
    "db:generate":  "prisma generate",
    "db:migrate":   "prisma migrate dev",
    "db:studio":    "prisma studio"
  },
  "dependencies": {
    "@hapi/joi":         "^16.1.8",
    "@prisma/client":    "^2.8.1",
    "axios":             "^0.21.0",
    "bullmq":            "^1.8.0",
    "dotenv":            "^8.2.0",
    "fastify":           "^3.7.0",
    "fastify-helmet":    "^5.3.2",
    "fastify-rate-limit":"^5.3.1",
    "ioredis":           "^4.19.2",
    "pino":              "^6.7.0",
    "pino-pretty":       "^4.3.0",
    "uuid":              "^8.3.1"
  },
  "devDependencies": {
    "@types/ioredis": "^4.17.4",
    "@types/jest":    "^26.0.15",
    "@types/node":    "^14.14.6",
    "@types/pino":    "^6.3.4",
    "@types/uuid":    "^8.3.0",
    "jest":           "^26.6.1",
    "nodemon":        "^2.0.6",
    "prisma":         "^2.8.1",
    "ts-jest":        "^26.4.1",
    "ts-node":        "^9.0.0",
    "tsconfig-paths": "^3.9.0",
    "typescript":     "^4.0.3"
  }
}
