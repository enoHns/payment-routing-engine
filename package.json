{
  "name": "payment-routing-engine",
  "version": "1.0.0",
  "description": "West Africa mobile money payment routing engine",
  "main": "dist/index.js",
  "engines": { "node": ">=16.0.0" },
  "scripts": {
    "build":        "tsc",
    "start":        "node dist/index.js",
    "dev":          "nodemon",
    "dev:once":     "ts-node -r tsconfig-paths/register src/index.ts",
    "test":         "vitest run",
    "test:coverage":"vitest run --coverage",
    "test:watch":   "vitest",
    "lint":         "tsc --noEmit",
    "db:generate":  "prisma generate",
    "db:migrate":   "prisma migrate dev",
    "db:studio":    "prisma studio"
  },
  "dependencies": {
    "@fastify/helmet":     "^10.1.1",
    "@fastify/rate-limit": "^7.6.0",
    "@prisma/client":      "^4.10.1",
    "axios":               "^1.3.1",
    "bullmq":              "^3.3.2",
    "dotenv":              "^16.0.3",
    "fastify":             "^4.12.0",
    "fastify-plugin":      "^4.5.0",
    "ioredis":             "^5.3.1",
    "pino":                "^8.10.0",
    "pino-pretty":         "^10.0.0",
    "uuid":                "^9.0.0",
    "zod":                 "^3.20.6"
  },
  "devDependencies": {
    "@types/node":           "^18.13.0",
    "@types/uuid":           "^9.0.0",
    "@vitest/coverage-v8":   "^0.28.5",
    "nodemon":               "^2.0.21",
    "prisma":                "^4.10.1",
    "ts-node":               "^10.9.1",
    "tsconfig-paths":        "^4.1.2",
    "typescript":            "^5.0.0-beta",
    "vitest":                "^0.28.5"
  }
}
