{
  "name": "payment-routing-engine",
  "version": "0.4.0",
  "description": "West Africa mobile money payment routing engine",
  "main": "dist/index.js",
  "engines": { "node": ">=12.0.0" },
  "scripts": {
    "build":        "tsc",
    "start":        "node dist/index.js",
    "dev":          "nodemon",
    "dev:once":     "ts-node -r tsconfig-paths/register src/index.ts",
    "test":         "jest --forceExit --detectOpenHandles",
    "test:coverage":"jest --forceExit --coverage",
    "test:watch":   "jest --watch",
    "lint":         "tsc --noEmit",
    "db:generate":  "prisma generate",
    "db:migrate":   "prisma migrate dev",
    "db:studio":    "prisma studio"
  },
  "dependencies": {
    "@hapi/joi":         "^16.1.8",
    "@prisma/client":    "^2.4.1",
    "axios":             "^0.19.2",
    "bull":              "^3.12.1",
    "dotenv":            "^8.2.0",
    "fastify":           "^3.0.0",
    "fastify-helmet":    "^5.0.3",
    "fastify-rate-limit":"^5.1.0",
    "ioredis":           "^4.17.3",
    "pino":              "^6.5.1",
    "pino-pretty":       "^4.0.0",
    "uuid":              "^8.1.0"
  },
  "devDependencies": {
    "@types/bull":    "^3.14.0",
    "@types/ioredis": "^4.17.3",
    "@types/jest":    "^26.0.0",
    "@types/node":    "^14.0.14",
    "@types/pino":    "^6.3.0",
    "@types/uuid":    "^8.0.0",
    "jest":           "^26.1.0",
    "nodemon":        "^2.0.4",
    "prisma":         "^2.4.1",
    "ts-jest":        "^26.1.1",
    "ts-node":        "^8.10.2",
    "tsconfig-paths": "^3.9.0",
    "typescript":     "^3.9.6"
  }
}
