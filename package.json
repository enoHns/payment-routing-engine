    "axios": "^0.19.2",
    "bull": "^3.12.1",
    "dotenv": "^8.2.0",
    "fastify": "^2.15.3",
    "fastify-helmet": "^3.0.2",
    "fastify-rate-limit": "^2.6.0",
    "ioredis": "^4.14.1",
    "pg": "^7.14.0",
    "pino": "^5.17.0",
    "pino-pretty": "^3.6.1",
    "typeorm": "^0.2.20",
    "uuid": "^3.4.0"
  },
  "devDependencies": {
    "@types/bull": "^3.10.7",
    "@types/ioredis": "^4.14.6",
    "@types/jest": "^24.0.23",
    "@types/node": "^12.12.6",
    "@types/pino": "^5.17.0",
    "@types/uuid": "^3.4.6",
    "jest": "^24.9.0",
    "nodemon": "^2.0.1",
    "ts-jest": "^24.1.0",
    "ts-node": "^8.5.4",
    "tsconfig-paths": "^3.9.0",
    "typescript": "^3.6.4"
  }
