{
  "name": "payment-routing-engine",
  "version": "0.10.0",
  "description": "West Africa mobile money payment routing engine",
  "main": "dist/index.js",
  "engines": { "node": ">=16.0.0" },
  "scripts": {
    "build":        "tsc",
    "start":        "node dist/index.js",
    "dev":          "nodemon",
    "dev:once":     "ts-node -r tsconfig-paths/register src/index.ts",
    "test":         "jest --forceExit --detectOpenHandles",
    "test:coverage":"jest --forceExit --coverage",
    "test:watch":   "jest --watch",
    "lint":         "tsc --noEmit",
    "db:generate":  "prisma generate",
    "db:migrate":   "prisma migrate dev",
    "db:studio":    "prisma studio"
  },
  "dependencies": {
    "@prisma/client":    "^3.9.2",
    "axios":             "^0.26.0",
    "bullmq":            "^1.70.0",
    "dotenv":            "^16.0.0",
    "fastify":           "^3.27.0",
    "fastify-helmet":    "^5.3.2",
    "fastify-plugin":    "^3.0.2",
    "fastify-rate-limit":"^5.8.0",
    "ioredis":           "^5.0.2",
    "pino":              "^7.8.0",
    "pino-pretty":       "^7.5.2",
    "uuid":              "^8.3.2",
    "zod":               "^3.14.4"
  },
  "devDependencies": {
    "@types/ioredis": "^5.0.0",
    "@types/jest":    "^27.4.1",
    "@types/node":    "^17.0.21",
    "@types/uuid":    "^8.3.4",
    "jest":           "^27.5.1",
    "nodemon":        "^2.0.15",
    "prisma":         "^3.9.2",
    "ts-jest":        "^27.1.3",
    "ts-node":        "^10.6.0",
    "tsconfig-paths": "^3.13.0",
    "typescript":     "^4.6.2"
  }
}
