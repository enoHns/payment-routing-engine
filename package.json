{
  "name": "payment-routing-engine",
  "version": "1.0.0-beta",
  "description": "West Africa mobile money payment routing engine",
  "main": "dist/index.js",
  "engines": { "node": ">=16.0.0" },
  "scripts": {
    "build":        "tsc",
    "start":        "node dist/index.js",
    "dev":          "nodemon",
    "dev:once":     "ts-node -r tsconfig-paths/register src/index.ts",
    "test":         "vitest run",
    "test:coverage":"vitest run --coverage",
    "test:watch":   "vitest",
    "lint":         "tsc --noEmit",
    "db:generate":  "prisma generate",
    "db:migrate":   "prisma migrate dev",
    "db:studio":    "prisma studio"
  },
  "dependencies": {
    "@fastify/helmet":     "^10.0.2",
    "@fastify/rate-limit": "^7.5.0",
    "@prisma/client":      "^4.1.1",
    "axios":               "^0.27.2",
    "bullmq":              "^1.90.1",
    "dotenv":              "^16.0.1",
    "fastify":             "^4.5.3",
    "fastify-plugin":      "^4.2.1",
    "ioredis":             "^5.2.3",
    "pino":                "^8.4.2",
    "pino-pretty":         "^9.1.0",
    "uuid":                "^9.0.0",
    "zod":                 "^3.17.10"
  },
  "devDependencies": {
    "@types/node":           "^18.6.5",
    "@types/uuid":           "^9.0.0",
    "@vitest/coverage-c8":   "^0.22.1",
    "nodemon":               "^2.0.19",
    "prisma":                "^4.1.1",
    "ts-node":               "^10.9.1",
    "tsconfig-paths":        "^4.1.0",
    "typescript":            "^4.8.2",
    "vitest":                "^0.22.1"
  }
}
