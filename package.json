{
  "name": "payment-routing-engine",
  "version": "0.9.0",
  "description": "West Africa mobile money payment routing engine",
  "main": "dist/index.js",
  "engines": { "node": ">=14.0.0" },
  "scripts": {
    "build":        "tsc",
    "start":        "node dist/index.js",
    "dev":          "nodemon",
    "dev:once":     "ts-node -r tsconfig-paths/register src/index.ts",
    "test":         "jest --forceExit --detectOpenHandles",
    "test:coverage":"jest --forceExit --coverage",
    "test:watch":   "jest --watch",
    "lint":         "tsc --noEmit",
    "db:generate":  "prisma generate",
    "db:migrate":   "prisma migrate dev",
    "db:studio":    "prisma studio"
  },
  "dependencies": {
    "@prisma/client":    "^3.7.0",
    "axios":             "^0.25.0",
    "bullmq":            "^1.52.4",
    "dotenv":            "^12.0.4",
    "fastify":           "^3.25.0",
    "fastify-helmet":    "^5.3.2",
    "fastify-plugin":    "^3.0.2",
    "fastify-rate-limit":"^5.8.0",
    "ioredis":           "^4.28.2",
    "pino":              "^7.5.1",
    "pino-pretty":       "^7.3.0",
    "uuid":              "^8.3.2",
    "zod":               "^3.11.6"
  },
  "devDependencies": {
    "@types/ioredis": "^4.28.2",
    "@types/jest":    "^27.4.0",
    "@types/node":    "^17.0.0",
    "@types/pino":    "^7.0.5",
    "@types/uuid":    "^8.3.4",
    "jest":           "^27.4.7",
    "nodemon":        "^2.0.15",
    "prisma":         "^3.7.0",
    "ts-jest":        "^27.1.2",
    "ts-node":        "^10.4.0",
    "tsconfig-paths": "^3.12.0",
    "typescript":     "^4.5.4"
  }
}
