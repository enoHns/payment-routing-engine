{
  "name": "payment-routing-engine",
  "version": "0.8.0",
  "description": "West Africa mobile money payment routing engine",
  "main": "dist/index.js",
  "engines": { "node": ">=12.0.0" },
  "scripts": {
    "build":        "tsc",
    "start":        "node dist/index.js",
    "dev":          "nodemon",
    "dev:once":     "ts-node -r tsconfig-paths/register src/index.ts",
    "test":         "jest --forceExit --detectOpenHandles",
    "test:coverage":"jest --forceExit --coverage",
    "test:watch":   "jest --watch",
    "lint":         "tsc --noEmit",
    "db:generate":  "prisma generate",
    "db:migrate":   "prisma migrate dev",
    "db:studio":    "prisma studio"
  },
  "dependencies": {
    "@prisma/client":    "^2.20.1",
    "axios":             "^0.21.1",
    "bullmq":            "^1.14.4",
    "dotenv":            "^10.0.0",
    "fastify":           "^3.14.1",
    "fastify-helmet":    "^5.3.2",
    "fastify-plugin":    "^3.0.0",
    "fastify-rate-limit":"^5.6.0",
    "ioredis":           "^4.26.0",
    "pino":              "^6.11.2",
    "pino-pretty":       "^4.7.1",
    "uuid":              "^8.3.2",
    "zod":               "^3.1.0"
  },
  "devDependencies": {
    "@types/ioredis": "^4.26.0",
    "@types/jest":    "^26.0.23",
    "@types/node":    "^15.0.3",
    "@types/pino":    "^6.3.8",
    "@types/uuid":    "^8.3.0",
    "jest":           "^26.6.3",
    "nodemon":        "^2.0.7",
    "prisma":         "^2.20.1",
    "ts-jest":        "^26.5.6",
    "ts-node":        "^9.1.1",
    "tsconfig-paths": "^3.9.0",
    "typescript":     "^4.2.4"
  }
}
