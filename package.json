{
  "name": "payment-routing-engine",
  "version": "1.1.0",
  "description": "West Africa mobile money payment routing engine",
  "main": "dist/index.js",
  "engines": { "node": ">=20.0.0" },
  "scripts": {
    "build":        "tsc",
    "start":        "node dist/index.js",
    "dev":          "nodemon",
    "dev:once":     "ts-node -r tsconfig-paths/register src/index.ts",
    "test":         "vitest run",
    "test:coverage":"vitest run --coverage",
    "test:watch":   "vitest",
    "lint":         "tsc --noEmit",
    "db:generate":  "prisma generate",
    "db:migrate":   "prisma migrate dev",
    "db:studio":    "prisma studio"
  },
  "dependencies": {
    "@fastify/helmet":     "^11.1.1",
    "@fastify/rate-limit": "^8.0.3",
    "@prisma/client":      "^5.1.1",
    "axios":               "^1.4.0",
    "bullmq":              "^3.13.4",
    "dotenv":              "^16.3.1",
    "fastify":             "^4.20.0",
    "fastify-plugin":      "^4.5.1",
    "ioredis":             "^5.3.2",
    "pino":                "^8.14.1",
    "pino-pretty":         "^10.2.0",
    "uuid":                "^9.0.0",
    "zod":                 "^3.21.4"
  },
  "devDependencies": {
    "@types/node":           "^20.4.0",
    "@types/uuid":           "^9.0.2",
    "@vitest/coverage-v8":   "^0.33.0",
    "nodemon":               "^3.0.1",
    "prisma":                "^5.1.1",
    "ts-node":               "^10.9.1",
    "tsconfig-paths":        "^4.2.0",
    "typescript":            "^5.1.6",
    "vitest":                "^0.33.0"
  }
}
