{
  "name": "payment-routing-engine",
  "version": "0.9.0",
  "description": "West Africa mobile money payment routing engine",
  "main": "dist/index.js",
  "engines": { "node": ">=12.0.0" },
  "scripts": {
    "build":        "tsc",
    "start":        "node dist/index.js",
    "dev":          "nodemon",
    "dev:once":     "ts-node -r tsconfig-paths/register src/index.ts",
    "test":         "jest --forceExit --detectOpenHandles",
    "test:coverage":"jest --forceExit --coverage",
    "test:watch":   "jest --watch",
    "lint":         "tsc --noEmit",
    "db:generate":  "prisma generate",
    "db:migrate":   "prisma migrate dev",
    "db:studio":    "prisma studio"
  },
  "dependencies": {
    "@prisma/client":    "^3.0.2",
    "axios":             "^0.24.0",
    "bullmq":            "^1.40.0",
    "dotenv":            "^10.0.0",
    "fastify":           "^3.21.0",
    "fastify-helmet":    "^5.3.2",
    "fastify-plugin":    "^3.0.2",
    "fastify-rate-limit":"^5.7.0",
    "ioredis":           "^4.27.6",
    "pino":              "^6.13.3",
    "pino-pretty":       "^7.0.0",
    "uuid":              "^8.3.2",
    "zod":               "^3.8.0"
  },
  "devDependencies": {
    "@types/ioredis": "^4.27.4",
    "@types/jest":    "^27.0.2",
    "@types/node":    "^16.9.0",
    "@types/pino":    "^6.3.11",
    "@types/uuid":    "^8.3.1",
    "jest":           "^27.2.0",
    "nodemon":        "^2.0.13",
    "prisma":         "^3.0.2",
    "ts-jest":        "^27.0.5",
    "ts-node":        "^10.2.1",
    "tsconfig-paths": "^3.11.0",
    "typescript":     "^4.4.3"
  }
}
