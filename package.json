{
  "name": "payment-routing-engine",
  "version": "1.0.0-beta",
  "description": "West Africa mobile money payment routing engine",
  "main": "dist/index.js",
  "engines": { "node": ">=16.0.0" },
  "scripts": {
    "build":        "tsc",
    "start":        "node dist/index.js",
    "dev":          "nodemon",
    "dev:once":     "ts-node -r tsconfig-paths/register src/index.ts",
    "test":         "jest --forceExit --detectOpenHandles",
    "test:coverage":"jest --forceExit --coverage",
    "test:watch":   "jest --watch",
    "lint":         "tsc --noEmit",
    "db:generate":  "prisma generate",
    "db:migrate":   "prisma migrate dev",
    "db:studio":    "prisma studio"
  },
  "dependencies": {
    "@fastify/helmet":     "^10.0.2",
    "@fastify/rate-limit": "^7.5.0",
    "@prisma/client":      "^3.14.0",
    "axios":               "^0.27.2",
    "bullmq":              "^1.86.7",
    "dotenv":              "^16.0.1",
    "fastify":             "^4.3.0",
    "fastify-plugin":      "^4.0.0",
    "ioredis":             "^5.2.2",
    "pino":                "^8.3.1",
    "pino-pretty":         "^9.0.0",
    "uuid":                "^9.0.0",
    "zod":                 "^3.17.10"
  },
  "devDependencies": {
    "@types/node":    "^18.0.0",
    "@types/uuid":    "^9.0.0",
    "@types/jest":    "^28.1.4",
    "jest":           "^28.1.3",
    "nodemon":        "^2.0.19",
    "prisma":         "^3.14.0",
    "ts-jest":        "^28.0.5",
    "ts-node":        "^10.8.2",
    "tsconfig-paths": "^4.0.0",
    "typescript":     "^4.7.4"
  }
}
