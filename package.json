{
  "name": "payment-routing-engine",
  "version": "1.2.2",
  "description": "West Africa mobile money payment routing engine",
  "main": "dist/index.js",
  "engines": { "node": ">=22.0.0" },
  "scripts": {
    "build":        "tsc",
    "start":        "node dist/index.js",
    "dev":          "nodemon",
    "dev:once":     "ts-node -r tsconfig-paths/register src/index.ts",
    "test":         "vitest run",
    "test:coverage":"vitest run --coverage",
    "test:watch":   "vitest",
    "lint":         "tsc --noEmit",
    "db:generate":  "prisma generate",
    "db:migrate":   "prisma migrate dev",
    "db:studio":    "prisma studio"
  },
  "dependencies": {
    "@fastify/helmet":     "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@prisma/client":      "^5.10.2",
    "axios":               "^1.8.4",
    "bullmq":              "^5.34.8",
    "dotenv":              "^16.4.7",
    "fastify":             "^4.28.1",
    "fastify-plugin":      "^4.5.1",
    "ioredis":             "^5.4.2",
    "pino":                "^9.6.0",
    "pino-pretty":         "^13.0.0",
    "uuid":                "^11.0.5",
    "zod":                 "^3.24.1"
  },
  "devDependencies": {
    "@types/node":           "^22.10.0",
    "@types/uuid":           "^10.0.0",
    "@vitest/coverage-v8":   "^4.1.7",
    "nodemon":               "^3.1.7",
    "prisma":                "^5.10.2",
    "ts-node":               "^10.9.2",
    "tsconfig-paths":        "^4.2.0",
    "typescript":            "^5.7.2",
    "vitest":                "^4.1.7"
  }
}
